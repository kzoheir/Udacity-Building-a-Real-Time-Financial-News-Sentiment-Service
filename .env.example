# MLflow
# Use host.docker.internal when running inside Docker (docker compose up)
# Use localhost:5000 when running locally (python app/main.py)
MLFLOW_TRACKING_URI="http://host.docker.internal:5000"
MLFLOW_EXPERIMENT_NAME=""
MODEL_NAME=""
MODEL_STAGE=dev

# AWS / ECR
AWS_REGION=""
AWS_ACCOUNT_ID=""   
ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
ECR_REPOSITORY=""

# Model source: "mlflow" (default) or "huggingface" (CI/prod)
MODEL_SOURCE=mlflow
HF_MODEL_ID=baptle/FinBERT_market_based
HF_DATASET_ID=baptle/financial_headlines_market_based

# API
API_HOST=0.0.0.0
API_PORT=8000
